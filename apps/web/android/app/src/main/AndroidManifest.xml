<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/AppTheme">

        <activity
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|locale|smallestScreenSize|screenLayout|uiMode|navigation|density"
            android:name=".MainActivity"
            android:label="@string/title_activity_main"
            android:theme="@style/AppTheme.NoActionBarLaunch"
            android:launchMode="singleTask"
            android:exported="true">

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!-- OAuth callback deep link. After Google sign-in the Custom Tab redirects
                 to khata://auth?ott=...; this custom scheme always routes back into the
                 app (no App Links / assetlinks.json verification required). -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="khata" />
            </intent-filter>

            <!-- Long-press launcher shortcut ("Add expense" -> khata://add). -->
            <meta-data
                android:name="android.app.shortcuts"
                android:resource="@xml/shortcuts" />

            <!-- FCM default channel. Must match the channel Capacitor creates on
                 first launch so notifications are never dropped to "Miscellaneous". -->
            <meta-data
                android:name="com.google.firebase.messaging.default_notification_channel_id"
                android:value="default" />

        </activity>

        <!-- Background UPI SMS ingest. Fires even when the app is closed; the
             receiver posts the SMS to the Convex ingest endpoint, authenticated
             by the per-device secret written via SmsPlugin.configureIngest. -->
        <receiver
            android:name=".SmsReceiver"
            android:exported="true"
            android:permission="android.permission.BROADCAST_SMS">
            <intent-filter android:priority="999">
                <action android:name="android.provider.Telephony.SMS_RECEIVED" />
            </intent-filter>
        </receiver>

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths"></meta-data>
        </provider>
    </application>

    <!-- Permissions -->

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.READ_SMS" />
    <!-- Background SMS auto-logging: receive UPI SMS while the app is closed. -->
    <uses-permission android:name="android.permission.RECEIVE_SMS" />
    <!-- Required for FCM push notifications on Android 13+ (API 33). Without this
         declaration the runtime permission request silently fails. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- In-app QR scanner (trip invites). getUserMedia in the WebView needs this;
         Capacitor brokers the runtime prompt. -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-feature android:name="android.hardware.camera" android:required="false" />
</manifest>
