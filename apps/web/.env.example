VITE_GOOGLE_CLIENT_ID=your-google-web-client-id.apps.googleusercontent.com
# Public origin used to build trip-invite links/QRs (e.g. https://khata.example.com).
# Falls back to the current origin if unset — set it for native/installed builds
# so shared links open on any device.
VITE_APP_URL=https://your-deployed-web-app.example.com
