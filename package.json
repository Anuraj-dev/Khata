{
  "name": "khata",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "web:dev": "bun run --cwd apps/web dev",
    "web:build": "bun run --cwd apps/web build",
    "web:preview": "bun run --cwd apps/web preview",
    "web:typecheck": "bun run --cwd apps/web typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "mobile:start": "bun run --cwd apps/mobile start",
    "mobile:start:tunnel": "bun run --cwd apps/mobile start:tunnel",
    "mobile:android": "bun run --cwd apps/mobile android",
    "mobile:ios": "bun run --cwd apps/mobile ios"
  },
  "dependencies": {
    "@convex-dev/better-auth": "^0.11.4",
    "better-auth": "1.5.3",
    "convex": "^1.34.1",
    "jose": "^6.2.3"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22",
    "convex-test": "^0.0.53",
    "jsdom": "^29.1.1",
    "typescript": "~5.9.2",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "react": "19.1.0",
    "react-dom": "19.1.0"
  }
}
